---
type CardVariant = 'default' | 'featured';

interface Props {
  /**
   * HTML element type, standaard <article>.
   */
  as?: 'article' | 'div' | 'section' | 'aside' | 'li';

  /**
   * Visuele variant van de kaart.
   */
  variant?: CardVariant;
}

const {
  as = 'article',
  variant = 'default',
  class: userClass,
  style: userStyle,
  ...forwardedProps
} = Astro.props as Props & {
  class?: unknown;
  style?: unknown;
} & Record<string, unknown>;

const Tag = as;
const cardClasses = ['card', typeof userClass === 'string' ? userClass : undefined]
  .filter(Boolean)
  .join(' ');
---

<Tag
  {...forwardedProps}
  class={cardClasses}
  data-variant={variant}
  style={typeof userStyle === 'string' ? userStyle : undefined}
>
  <slot />
</Tag>

<style>
  .card {
    --_card-bg: var(--theme-color-surface);
    --_card-text-color: var(--theme-color-text);
    --_card-border-color: var(--theme-color-border);
    --_card-padding: var(--space-5);
    --_card-gap: var(--space-3);
    --_card-border-width: 1px;
    --_card-radius: 0.75rem;

    background: var(--_card-bg);
    color: var(--_card-text-color);
    border: var(--_card-border-width) solid var(--_card-border-color);
    border-radius: var(--_card-radius);
    padding: var(--_card-padding);
    display: flex;
    flex-direction: column;
    gap: var(--_card-gap);
  }

  .card[data-variant='featured'] {
    --_card-bg: color-mix(in srgb, var(--theme-color-accent) 10%, var(--theme-color-surface));
    --_card-border-color: color-mix(in srgb, var(--theme-color-accent) 60%, var(--theme-color-border));
    --_card-border-width: 2px;
  }
</style>
