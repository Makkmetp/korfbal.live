---
type CardVariant = "default" | "featured";

interface Props {
  /**
   * HTML element type, standaard <article>.
   */
  as?: "article" | "div" | "section" | "aside" | "li";

  /**
   * Visuele variant van de kaart.
   */
  variant?: CardVariant;
}

const {
  as = "article",
  variant = "default",
  class: userClass,
  style: userStyle,
  ...forwardedProps
} = Astro.props as Props & {
  class?: unknown;
  style?: unknown;
} & Record<string, unknown>;

const Tag = as;
const cardClasses = [
  "card",
  typeof userClass === "string" ? userClass : undefined,
]
  .filter(Boolean)
  .join(" ");
---

<Tag
  {...forwardedProps}
  class={cardClasses}
  data-variant={variant}
  style={typeof userStyle === "string" ? userStyle : undefined}
>
  <div class="card__layout">
    <div class="card__content">
      <slot />
    </div>
  </div>
</Tag>

<style>
  .card {
    --_card-bg: var(--theme-color-surface);
    --_card-text-color: var(--theme-color-text);
    --_card-border-color: var(--theme-color-border);
    --_card-padding: var(--space-5);
    --_card-gap: var(--space-3);
    --_card-radius: 1.5rem;

    display: flex;
    width: 100%;
    height: 100%;

    /* 
    color: var(--_card-text-color);
    border: var(--_card-border-width) solid var(--_card-border-color);
    border-radius: var(--_card-radius);
    padding: var(--_card-padding);
    display: flex;
    flex-direction: column;
    gap: var(--_card-gap); */
  }

  .card__layout {
    background: var(--_card-bg);
    position: relative;
    width: 100%;
    border-radius: var(--_card-radius);
    padding: calc(
      var(--space-7) * max(var(--responsive-large), var(--responsive-medium)) +
        var(--space-5) * max(var(--responsive-small), var(--responsive-xsmall))
    );
  }

  .card[data-variant="featured"] {
    --_card-bg: color-mix(
      in srgb,
      var(--theme-color-accent) 10%,
      var(--theme-color-surface)
    );
    --_card-border-color: color-mix(
      in srgb,
      var(--theme-color-accent) 60%,
      var(--theme-color-border)
    );
    --_card-border-width: 2px;
  }
</style>
