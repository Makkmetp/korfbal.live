---
import { IconBrandFacebook, IconBrandInstagram, IconBrandLinkedin } from "./icons";


const year = new Date().getFullYear();
---

<footer class="footer" data-theme="dark">
  <div class="footer__inner">
    <div class="footer__grid">
      <div class="footer__brand-col">
        <a class="footer__brand" href="/" aria-label="Ga naar homepage">
          <img
            src="/images/kl-logo-horizontal-dark.svg"
            alt="Korfbal.live"
            width="220"
          />
        </a>

        <p class="footer__copyright">
          © {year} Korfbal.live, Alle rechten voorbehouden
        </p>

        <ul class="footer__socials" role="list" aria-label="Social media links">
          <li>
            <a class="footer__social-link" href="#" aria-label="Facebook">
              <IconBrandFacebook />
            </a>
          </li>
          <li>
            <a class="footer__social-link" href="#" aria-label="Instagram">
              <IconBrandInstagram />
            </a>
          </li>
          <li>
            <a class="footer__social-link" href="#" aria-label="LinkedIn">
              <IconBrandLinkedin />
            </a>
          </li>
        </ul>
      </div>

      <div class="footer__links-col">
        <p class="footer__heading">Product</p>
        <ul class="footer__links" role="list">
          <li><a class="footer__link" href="/features#features-registration">Wedstrijdregistratie</a></li>
          <li><a class="footer__link" href="/features#features-live-stream">Live Stream</a></li>
          <li><a class="footer__link" href="/features#features-live-dashboard">Live Dashboard</a></li>
          <li><a class="footer__link" href="/features#features-statistics">Statistieken</a></li>
          <li><a class="footer__link" href="/abonnementen">Abonnementen</a></li>
          <li><a class="footer__link" href="/handleiding">Handleiding</a></li>
        </ul>
      </div>

      <div class="footer__links-col">
        <p class="footer__heading">Korfbal.live</p>
        <ul class="footer__links" role="list">
          <li><a class="footer__link" href="/over-ons#wie-zijn-wij">Over ons</a></li>
          <li><a class="footer__link" href="mailto:info@korfbal.live?subject=Contact via korfbal.live">Contact</a></li>
          <li><a class="footer__link" href="/algemene-voorwaarden#algemene-voorwaarden">Veelgestelde vragen</a></li>
          <li><a class="footer__link" href="/privacyverklaring#privacyverklaring">Privacyverklaring</a></li>
          <li><a class="footer__link" href="/algemene-voorwaarden#algemene-voorwaarden">Algemene voorwaarden</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--theme-color-bg);
    color: var(--theme-color-text);
    display: flex;
    position: relative;
    isolation: isolate;
    padding-block: var(--space-section-md);
  }

  .footer__inner {
    margin-inline: auto;
    max-width: var(--layout-max-width);
    width: calc(100% - (var(--section-padding-x, var(--layout-page-margin)) * 2));
    container-type: inline-size;
  }

  .footer__grid {
    display: grid;
    gap: var(--space-7);
  }

  .footer__brand-col {
    display: grid;
    gap: var(--space-4);
    align-content: start;
  }

  .footer__brand {
    display: inline-flex;
    width: fit-content;
  }

  .footer__brand img {
    width: clamp(9.5rem, 18vw, 11.3rem);
    height: auto;
    display: block;
  }

  .footer__copyright {
    margin: 0;
    color: color-mix(in srgb, var(--theme-color-text) 72%, transparent);
    font-size: var(--text-style-body-sm-font-size);
    line-height: var(--text-style-body-sm-line-height);
    letter-spacing: var(--text-style-body-sm-letter-spacing);
  }

  .footer__socials {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    color: color-mix(in srgb, var(--theme-color-text) 72%, transparent);
    transition: color .2s ease, transform .2s ease;
  }

  .footer__social-link:hover,
  .footer__social-link:focus-visible {
    color: var(--theme-color-text);
    transform: translateY(-1px);
  }

  .footer__social-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--theme-button-focus-color);
    outline-offset: var(--focus-ring-offset-outer);
    border-radius: 0.25rem;
  }

  .footer__social-link svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .footer__links-col {
    display: grid;
    align-content: start;
    gap: var(--space-2);
  }

  .footer__heading {
    margin: 0;
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-normal);
  }

  .footer__links {
    list-style: none;
    display: grid;
    gap: .35rem;
    margin: 0;
    padding: 0;
  }

  .footer__link {
    color: color-mix(in srgb, var(--theme-color-text) 78%, transparent);
    text-decoration: none;
    font-size: var(--text-style-body-font-size);
    line-height: var(--text-style-body-line-height);
    letter-spacing: var(--text-style-body-letter-spacing);
    transition: color .2s ease;
  }

  .footer__link:hover,
  .footer__link:focus-visible {
    color: var(--theme-color-text);
  }

  .footer__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--theme-button-focus-color);
    outline-offset: var(--focus-ring-offset-outer);
    border-radius: 0.125rem;
  }

  @container (min-width: 48rem) {
    .footer__grid {
      grid-template-columns: minmax(17rem, 1.4fr) minmax(11rem, 1fr) minmax(11rem, 1fr);
      gap: clamp(2rem, 4vw, 5rem);
    }
  }
</style>
