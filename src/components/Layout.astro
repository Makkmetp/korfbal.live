---
type LayoutVariant = 'stack' | 'columns';
type LayoutGap = 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl';
type LayoutAlign = 'start' | 'center' | 'end' | 'stretch';

interface Props {
  /**
   * Layout variant.
   * Ondersteunt "stack" en "columns".
   */
  variant?: LayoutVariant;

  /**
   * Verticale ruimte tussen de twee kolommen in stack.
   */
  gap?: LayoutGap;

  /**
   * Cross-axis alignment van de kolommen.
   */
  align?: LayoutAlign;
}

const {
  variant = 'stack',
  gap = 'lg',
  align = 'stretch',
  class: userClass,
  style: userStyle,
  ...forwardedProps
} = Astro.props as Props & {
  class?: unknown;
  style?: unknown;
} & Record<string, unknown>;

const hasColumn1 = Astro.slots.has('column-1');
const hasColumn2 = Astro.slots.has('column-2');
const layoutClasses = ['layout', typeof userClass === 'string' ? userClass : undefined]
  .filter(Boolean)
  .join(' ');
---

<div
  {...forwardedProps}
  class={layoutClasses}
  data-variant={variant}
  data-gap={gap}
  data-align={align}
  data-has-column-2={hasColumn2 ? 'true' : 'false'}
  style={typeof userStyle === 'string' ? userStyle : undefined}
>
  <div class="layout__inner">
    <div class="layout__column layout__column--primary">
      {hasColumn1 ? <slot name="column-1" /> : <slot />}
    </div>
    {hasColumn2 && (
      <div class="layout__column layout__column--secondary">
        <slot name="column-2" />
      </div>
    )}
  </div>
</div>

<style>
  .layout {
    column-gap: var(--layout-gutter);
    row-gap: var(--space-8);
    justify-content: center;
    align-items: stretch;
    width: 100%;
    display: flex;
    container-type: inline-size;
  }

  .layout__inner {
    column-gap: inherit;
    row-gap: inherit;
    flex-flow: column;
    grid-template-rows: auto;
    grid-auto-columns: 1fr;
    width: 100%;
    display: flex;
  }

  .layout[data-variant='columns'][data-has-column-2='true'] > .layout__inner {
    display: var(--layout-columns-display, grid);
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: stretch;
  }

  .layout__column--primary {
    align-self: center;
    width: 100%;
    position: relative;
  }

  .layout__column--secondary {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius--main, 0);
    width: 100%;
    height: 100%;
    position: relative;
    overflow: clip;
  }

  .layout[data-has-column-2='true'] .layout__column--secondary:has(> :not(.image-wrapper, .video, .iframe-wrapper, .overlay)) {
    aspect-ratio: auto;
    border-radius: 0;
    overflow: visible;
  }

  .layout[data-gap='none'] {
    row-gap: 0;
  }

  .layout[data-gap='xs'] {
    row-gap: var(--space-2);
  }

  .layout[data-gap='sm'] {
    row-gap: var(--space-3);
  }

  .layout[data-gap='md'] {
    row-gap: var(--space-5);
  }

  .layout[data-gap='lg'] {
    row-gap: var(--space-8);
  }

  .layout[data-gap='xl'] {
    row-gap: var(--space-section-md);
  }

  .layout[data-align='start'] .layout__inner {
    align-items: flex-start;
  }

  .layout[data-align='center'] .layout__inner {
    align-items: center;
  }

  .layout[data-align='end'] .layout__inner {
    align-items: flex-end;
  }

  .layout[data-align='stretch'] .layout__inner {
    align-items: stretch;
  }

  @container (width < 50em) {
    .layout[data-variant='columns'][data-has-column-2='true'] > .layout__inner {
      --layout-columns-display: flex;
      flex-flow: column;
    }
  }
</style>

