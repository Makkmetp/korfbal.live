---
type LayoutVariant = 'stack' | 'columns' | 'columns-7-5';

interface Props {
  /**
   * Layout variant.
   * Ondersteunt "stack", "columns" en "columns-7-5".
   */
  variant?: LayoutVariant;

  /**
   * Keer de visuele volgorde van primary en secondary om.
   */
  reversed?: boolean;
}

const {
  variant = 'stack',
  reversed = false,
  class: userClass,
  style: userStyle,
  ...forwardedProps
} = Astro.props as Props & {
  class?: unknown;
  style?: unknown;
} & Record<string, unknown>;

const _hasContentPrimary = Astro.slots.has('content-primary') || Astro.slots.has('column-1');
const _hasContentSecondary = Astro.slots.has('content-secondary') || Astro.slots.has('column-2');
const layoutClasses = ['layout', typeof userClass === 'string' ? userClass : undefined]
  .filter(Boolean)
  .join(' ');
---

<div
  {...forwardedProps}
  class={layoutClasses}
  data-variant={variant}
  data-reversed={reversed}
  style={typeof userStyle === 'string' ? userStyle : undefined}
>
  <div class="layout__inner">
    <div class="layout__content layout__content--primary">
      {_hasContentPrimary ? (
        Astro.slots.has('content-primary') ? <slot name="content-primary" /> : <slot name="column-1" />
      ) : (
        <slot />
      )}
    </div>
    {_hasContentSecondary && (
      <div class="layout__content layout__content--secondary">
        {Astro.slots.has('content-secondary') ? <slot name="content-secondary" /> : <slot name="column-2" />}
      </div>
    )}
  </div>
</div>

<style>
  .layout {
    --_layout-display: flex;
    --_layout-grid-template-columns: 1fr;
    
    column-gap: var(--layout-gutter);
    row-gap: var(--space-8);
    justify-content: center;
    align-items: stretch;
    width: 100%;
    display: flex;
    /* container-type: inline-size; */
  }

  .layout[data-variant='columns'] {
    --_layout-display: grid;
    --_layout-grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .layout[data-variant='columns-7-5'] {
    --_layout-display: grid;
    --_layout-grid-template-columns: repeat(12, minmax(0, 1fr));
    --_layout-primary-columns: 7;
    --_layout-secondary-columns: 5;
  }

  .layout[data-reversed='true'] {
    --_layout-secondary-order: -1
  }

  .layout__inner {
    column-gap: inherit;
    row-gap: inherit;
    flex-flow: column;
    align-items: stretch;
    grid-template-columns: var(--_layout-grid-template-columns);
    width: 100%;
    display: var(--flex-medium, var(--_layout-display));
  }

  .layout__content--primary {
    grid-column: span var(--_layout-primary-columns, 1);
    align-self: center;
    display: flex;
    flex-flow: column;
    gap: var(--space-3);
  }

  .layout__content--secondary {
    grid-column: span var(--_layout-secondary-columns, 1);
    text-align: center;
    order: calc(var(--_layout-secondary-order, 0) * var(--responsive-large, 0));
  }
</style>

