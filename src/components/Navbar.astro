---
import Button from "./Button.astro";
import { IconClose, IconMenu } from "./icons";
---

<header class="navbar">
  <div class="navbar__element" data-open="false">
    <a class="navbar__brand" href="/" aria-label="Ga naar homepage">
      <img src="images/kl-logo-horizontal.svg" alt="Korfbal.live">
    </a>

    <button
      class="navbar__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="navbar-menu"
      aria-label="Open navigatiemenu"
    >
      <span class="navbar__toggle-icon navbar__toggle-icon--menu" aria-hidden="true">
        <IconMenu size={24} />
      </span>
      <span class="navbar__toggle-icon navbar__toggle-icon--close" aria-hidden="true">
        <IconClose size={24} />
      </span>
    </button>

    <div class="navbar__panel" id="navbar-menu">
      <nav class="navbar__nav" aria-label="Hoofdnavigatie">
        <ul class="navbar__list" role="list">
          <li><a class="navbar__link" href="/">Home</a></li>
          <li><a class="navbar__link" href="/features">Hoe het werkt</a></li>
          <li><a class="navbar__link" href="/abonnementen">Abonnementen</a></li>
          <li><a class="navbar__link" href="/over-ons">Over ons</a></li>
        </ul>
      </nav>

      <div class="navbar__cta-button">
        <Button href="https://app.korfbal.live/registreren">Start gratis</Button>
      </div>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    pointer-events: none;
  }

  .navbar__element {
    width: calc(100% - (var(--nav-padding-x) * 2));
    max-width: 60rem;
    min-height: var(--nav-height);
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    container-type: inline-size;
    background-color: white;
    border-radius: var(--nav-radius);
    box-shadow: var(--theme-shadow-subtle);
    margin-top: var(--space-6);
    padding-inline: var(--nav-padding-x);
    padding-block: 0;
    pointer-events: auto;
  }

  .navbar__brand {
    font-family: var(--font-family-base);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-body-lg);
    color: var(--theme-color-text);
    line-height: 1;
    white-space: nowrap;
    max-width: 10rem;
  }

  .navbar__toggle {
    display: none;
    position: relative;
    z-index: 41;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 0;
    border-radius: 0;
    background: white;
    color: var(--theme-link-text);
    cursor: pointer;
  }

  .navbar__toggle:hover,
  .navbar__toggle:focus-visible {
    color: var(--theme-link-text-hover);
  }

  .navbar__toggle:focus-visible {
    outline: var(--focus-ring-width) solid var(--theme-button-focus-color);
    outline-offset: var(--focus-ring-offset-outer);
  }

  .navbar__toggle-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .navbar__toggle-icon--close {
    display: none;
  }

  .navbar__element[data-open="true"] .navbar__toggle-icon--menu {
    display: none;
  }

  .navbar__element[data-open="true"] .navbar__toggle-icon--close {
    display: block;
  }

  .navbar__panel {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin-inline-start: auto;
  }

  .navbar__list {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    justify-content: flex-start;
    flex-wrap: nowrap;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .navbar__link {
    color: var(--theme-link-text);
    font-weight: var(--font-weight-medium);
    border-bottom: 2px solid transparent;
    padding-bottom: 0.2em;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .navbar__link:hover,
  .navbar__link:focus-visible {
    color: var(--theme-link-text-hover);
    border-color: var(--theme-link-border-hover);
  }

  .navbar__cta-button {
    white-space: nowrap;
  }

  @container (width < 50em) {
    .navbar__element {
      flex-wrap: wrap;
      row-gap: var(--space-2);
      padding-block: var(--space-2);
    }

    .navbar__toggle {
      display: inline-flex;
    }

    .navbar__panel {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 40;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      gap: var(--space-5);
      margin-inline-start: 0;
      padding-block: calc(var(--nav-height) + 3rem) var(--space-5);
      padding-inline: var(--nav-padding-x);
      background: white;
      overflow-y: auto;
    }

    .navbar__element[data-open="true"] .navbar__panel {
      display: flex;
    }

    .navbar__list {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .navbar__cta-button {
      width: 100%;
      white-space: initial;
    }

    .navbar__cta-button :global(.button) {
      width: 100%;
    }
  }
</style>

<script>
  const navbarElements = document.querySelectorAll<HTMLElement>(".navbar__element");
  let openOverlayCount = 0;

  const updateBodyScrollLock = () => {
    if (openOverlayCount > 0) {
      document.body.style.overflow = "hidden";
      return;
    }

    document.body.style.removeProperty("overflow");
  };

  navbarElements.forEach((navbarElement) => {
    const toggle = navbarElement.querySelector<HTMLButtonElement>(".navbar__toggle");

    if (!toggle) return;

    let isOverlayOpen = false;

    const setOpenState = (isOpen: boolean) => {
      const shouldLockScroll = isOpen && window.getComputedStyle(toggle).display !== "none";

      if (shouldLockScroll !== isOverlayOpen) {
        openOverlayCount += shouldLockScroll ? 1 : -1;
        isOverlayOpen = shouldLockScroll;
        updateBodyScrollLock();
      }

      navbarElement.dataset.open = isOpen ? "true" : "false";
      toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      toggle.setAttribute(
        "aria-label",
        isOpen ? "Sluit navigatiemenu" : "Open navigatiemenu",
      );
    };

    toggle.addEventListener("click", () => {
      const isOpen = navbarElement.dataset.open === "true";
      setOpenState(!isOpen);
    });

    navbarElement.querySelectorAll<HTMLAnchorElement>(".navbar__link").forEach((link) => {
      link.addEventListener("click", () => setOpenState(false));
    });

    window.addEventListener("resize", () => {
      if (window.getComputedStyle(toggle).display === "none") {
        setOpenState(false);
      }
    });
  });
</script>
