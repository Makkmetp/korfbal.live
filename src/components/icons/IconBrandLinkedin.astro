---
interface Props {
  size?: number | string;
  strokeWidth?: number | string;
  class?: string;
  title?: string;
  decorative?: boolean;
}

const {
  size = 24,
  strokeWidth = 1.5,
  class: className = "",
  title = "Brand Linkedin",
  decorative = true,
} = Astro.props;
---

<svg class={className} xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={strokeWidth} stroke-linecap="round" stroke-linejoin="round"
  aria-hidden={decorative ? "true" : "false"}
  role={decorative ? undefined : "img"}>
  {!decorative && <title>{title}</title>}<path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 11v5" /><path d="M8 8v.01" /><path d="M12 16v-5" /><path d="M16 16v-3a2 2 0 1 0 -4 0" /><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4l0 -10" /></svg>