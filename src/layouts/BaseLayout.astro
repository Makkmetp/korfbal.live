---
import "../styles/reset.css";
import "../styles/fonts.css";
import "../styles/tokens.css";
import "../styles/utilities/index.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const OG_IMAGE_PATH = "/korfbal-live-og-image.webp";
const OG_IMAGE_WIDTH = 1200;
const OG_IMAGE_HEIGHT = 630;

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  lang?: string;
  /** Korte beschrijving van de social preview-afbeelding (toegankelijkheid). */
  ogImageAlt?: string;
}

const {
  title = "Korfbal.live",
  description = "Korfbal.live helpt trainers en coaches wedstrijden live te volgen, te delen en te analyseren met duidelijke statistieken.",
  canonical,
  lang = "nl",
  ogImageAlt,
} = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(OG_IMAGE_PATH, Astro.site).toString();
const resolvedOgImageAlt = ogImageAlt ?? title;
const ogLocale = lang === "nl" ? "nl_NL" : lang.replace("-", "_");
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://korfbal.live/#organization",
      name: "Korfbal.live",
      url: "https://korfbal.live/",
    },
    {
      "@type": "WebSite",
      "@id": "https://korfbal.live/#website",
      name: "Korfbal.live",
      url: "https://korfbal.live/",
      inLanguage: lang,
      publisher: {
        "@id": "https://korfbal.live/#organization",
      },
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- ✅ Content Security Policy -->
    <meta http-equiv="Content-Security-Policy" content="
      default-src 'self';
      img-src 'self' data: https:;
      style-src 'self' 'unsafe-inline';
      script-src 'self' https://cloud.umami.is;
      font-src 'self' data: https:;
      connect-src 'self' https://cloud.umami.is;
      frame-ancestors 'self';
      base-uri 'self';
      form-action 'self';
    " />

    <!-- ✅ Referrer Policy -->

    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Korfbal.live" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:alt" content={resolvedOgImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={resolvedOgImageAlt} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    ></script>
    <title>{title}</title>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="741b78b1-8001-4cd5-9de7-4825b663ede3"></script>
  </head>
  <body data-theme="light">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  body {
    background-color: var(--theme-color-bg);
    color: var(--theme-color-text);
  }
</style>
