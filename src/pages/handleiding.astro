---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Layout from "../components/Layout.astro";

const pageTitle = "Handleiding | Korfbal.live";
const pageDescription =
  "Gebruik de handleiding van Korfbal.live om snel te starten met teambeheer, wedstrijdregistratie, live delen en statistieken.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main>
    <Section
      id="handleiding"
      paddingBlockStart="page-top"
      paddingBlockEnd="large"
    >
      <div class="guide">
        <aside class="guide__nav" aria-label="Op deze pagina">
          <div class="guide__nav-inner">
            <nav>
              <details class="guide__nav-dropdown">
                <summary class="guide__nav-summary">
                  <span class="guide__nav-summary-label">Ga naar onderdeel</span>
                  <span class="guide__nav-summary-current">Snel starten</span>
                </summary>
                <ul class="guide__nav-dropdown-list">
                  <li>
                    <a class="guide__nav-link guide__nav-link--dropdown" href="#snel-starten"
                      >Snel starten</a
                    >
                  </li>
                  <li>
                    <a class="guide__nav-link guide__nav-link--dropdown" href="#uitleg-menu"
                      >Het menu uitgelegd</a
                    >
                  </li>
                  <li>
                    <a class="guide__nav-link guide__nav-link--dropdown" href="#team-aanmaken"
                      >Team aanmaken</a
                    >
                  </li>
                  <li>
                    <a
                      class="guide__nav-link guide__nav-link--dropdown"
                      href="#wedstrijd-vastleggen">Wedstrijd vastleggen</a
                    >
                  </li>
                  <li>
                    <a class="guide__nav-link guide__nav-link--dropdown" href="#wedstrijd-delen"
                      >Wedstrijd delen</a
                    >
                  </li>
                  <li>
                    <a class="guide__nav-link guide__nav-link--dropdown" href="#statistieken"
                      >Statistieken uitgelegd</a
                    >
                  </li>
                </ul>
              </details>
              <ul class="guide__nav-list">
                <li><a class="guide__nav-link" href="#snel-starten">Snel starten</a></li>
                <li><a class="guide__nav-link" href="#uitleg-menu">Het menu uitgelegd</a></li>
                <li><a class="guide__nav-link" href="#team-aanmaken">Team aanmaken</a></li>
                <li>
                  <a class="guide__nav-link" href="#wedstrijd-vastleggen">Wedstrijd vastleggen</a>
                </li>
                <li><a class="guide__nav-link" href="#wedstrijd-delen">Wedstrijd delen</a></li>
                <li><a class="guide__nav-link" href="#statistieken">Statistieken uitgelegd</a></li>
              </ul>
            </nav>
          </div>
        </aside>
        <article class="guide__content">
          <h1>Handleiding korfbal.live</h1>

          <section id="snel-starten" class="guide__section">
            <h2>Snel starten</h2>
            <p>
              De snelste manier om een wedstrijd vast te leggen is als volgt:
            </p>
            <ol>
              <li>
                Team aanmaken en spelers toevoegen via het menu-item <strong
                  >Team</strong
                >.
              </li>
              <li>
                Via het menu-item <strong>Wedstrijden</strong> maak je een eerste
                wedstrijd aan.
              </li>
              <li>
                Wedstrijd vastleggen starten doe je via de aangemaakte wedstrijd
                onderaan.
              </li>
              <li>
                Nadat de wedstrijd is gestart kunnen acties vastgelegd worden.
              </li>
              <li>
                Via de knop in het scorebord (<strong>Start</strong>) is het
                volgende deel van de wedstrijd aan te geven: rust, hervat voor
                de tweede helft en einde.
              </li>
            </ol>
          </section>

          <section id="uitleg-menu" class="guide__section">
            <h2>Het menu uitgelegd</h2>
            <img
              src="/images/menu.png"
              alt="Afbeelding van het menu"
              class="guide__image"
            />
            <p>
              Via het menu-item <strong>Team</strong> kunnen spelers worden toegevoegd.
            </p>
            <ul>
              <li>
                <strong>Wedstrijden</strong> - maak een wedstrijd aan om alle acties
                vast te leggen.
              </li>
              <li>
                <strong>Team</strong> - voor het aanmaken van je team en spelers.
                Vergeet niet om je teamnaam op te voeren.
              </li>
              <li>
                <strong>Statistieken</strong> - de plek om alle verzamelde statistieken
                in te zien. Dit kan over het gehele seizoen, per wedstrijd en per
                speler.
              </li>
              <li>
                <strong>Meer</strong> - om uit te loggen, de voorwaarden te lezen
                en de handleiding te openen.
              </li>
            </ul>
          </section>

          <section id="team-aanmaken" class="guide__section">
            <h2>Team aanmaken</h2>
            <p>
              Via het menu-item <strong>Team</strong> kunnen spelers worden toegevoegd.
            </p>
            <ul>
              <li>
                Via het potlood-icoon kan bovenaan een teamnaam worden ingevuld.
                Deze wordt getoond in het liveverslag.
              </li>
              <li class="guide__list-image">
                <img
                  src="/images/potlood.png"
                  alt="Icoon van een potlood"
                  class="guide__image guide__image--small"
                />
              </li>
              <li>
                Met de knop <strong>Speler toevoegen</strong> voeg je spelers toe.
                De volgorde bepaalt de weergave in de app. Voeg als je deze weet ook
                direct reservespelers toe. Dat maakt wisselen tijdens de wedstrijd
                makkelijker.
              </li>
              <li>
                Een gastspeler kan tijdens de wedstrijd nog toegevoegd worden
                via <strong>Wissel</strong>.
              </li>
            </ul>
          </section>

          <section id="wedstrijd-vastleggen" class="guide__section">
            <h2>Wedstrijd vastleggen</h2>
            <p>Voor het vastleggen van de wedstrijd zijn twee stappen nodig:</p>
            <ul>
              <li>Een wedstrijd aanmaken</li>
              <li>De acties van de wedstrijd vastleggen</li>
            </ul>

            <h3>Wedstrijd aanmaken</h3>
            <p>
              Via het menu-item <strong>Wedstrijden</strong> wordt een nieuwe wedstrijd
              aangemaakt.
            </p>
            <img
              src="/images/wedstrijd_aanmaken.png"
              alt="Formulier met acties om een wedstrijd aan te maken"
              class="guide__image"
            />
            <p>Geef aan:</p>
            <ul>
              <li>Tegen wie de wedstrijd wordt gespeeld</li>
              <li>Op welke datum de wedstrijd wordt gespeeld</li>
              <li>Of je thuis of uit speelt</li>
              <li>Of het een wedstrijd op het veld of in de zaal is</li>
              <li>
                Welke spelers in de aanval starten en welke spelers in de
                verdediging starten
              </li>
            </ul>
            <p>
              Nadat op <strong>Wedstrijd registreren</strong> is geklikt, kunnen de
              verschillende acties vastgelegd worden.
            </p>

            <h3>Wedstrijd starten</h3>
            <p>
              Om acties vast te leggen dient de wedstrijd eerst gestart te
              worden. Dat doe je door op de knop
              <strong>Start</strong> op het scorebord te klikken. Daarna verandert
              de knop naar
              <strong>Rust</strong>.
            </p>
            <img
              src="/images/scorebord_start.png"
              alt="Inactief scorebord met startknop"
              class="guide__image"
            />
            <img
              src="/images/scorebord_rust.png"
              alt="Geactiveerd scorebord met rustknop"
              class="guide__image"
            />
            <p>
              Het is nu mogelijk om verschillende acties van de wedstrijd vast
              te leggen.
            </p>

            <h3>Time-out</h3>
            <p>
              Naast de knop <strong>Rust</strong> staat een <strong
                >Pauze-knop</strong
              >. Met deze knop worden time-outs vastgelegd. Wanneer je erop
              klikt, opent een venster waarin je aangeeft welk team de time-out
              heeft aangevraagd.
            </p>
            <img
              src="/images/time_out.png"
              alt="Time-out venster met twee teamnamen"
              class="guide__image"
            />

            <h3>Acties vastleggen</h3>
            <p>
              Boven het scorebord staan meerdere knoppen waarmee acties
              vastgelegd kunnen worden.
            </p>
            <img
              src="/images/acties_vastleggen.png"
              alt="Knoppen om acties vast te leggen"
              class="guide__image"
            />

            <h4>Strafworpen en vrije ballen</h4>
            <p>
              Met <strong>Strafworp</strong> en <strong>Vrije bal</strong> worden
              deze doelpogingen voor je eigen team vastgelegd. Daarna kies je de speler
              uit de aanval en het resultaat:
              <strong>raak</strong>, <strong>op de korf</strong> of <strong
                >mis</strong
              >.
            </p>
            <img
              src="/images/selecteer_speler.png"
              alt="Formulier om speler te selecteren"
              class="guide__image"
            />

            <h4>Tegendoelpunten</h4>
            <p>
              <strong>Tegendoelpunten</strong> worden vastgelegd met de knop <strong
                >Tegendoel</strong
              >. Je selecteert vervolgens de verdediger die het tegendoelpunt
              heeft doorgelaten.
            </p>
            <img
              src="/images/selecteer_verdediger.png"
              alt="Formulier om verdediger te selecteren"
              class="guide__image"
            />

            <h4>Aantal aanvallen</h4>
            <p>
              Elke keer dat de bal in het aanvalsvak in bezit komt voor een
              nieuwe aanval kun je dit registreren met
              <strong>Start nieuwe aanval</strong>. Dit is niet verplicht, maar
              levert inzicht op in het gemiddeld aantal doelpogingen per aanval.
            </p>

            <h4>Doelpogingen vastleggen</h4>
            <p>
              Het korfbalveld is verdeeld in meerdere cirkels. Tussen de cirkels
              zit drie meter. Dit helpt bij het inschatten van de positie van de
              doelpoging.
            </p>
            <p>Overzicht van de typen doelpogingen binnen de cirkels:</p>
            <ul>
              <li>
                <strong>Binnen de 6 meter</strong> - doorloop of korte kans
              </li>
              <li><strong>Buiten de 6 meter</strong> - afstandsschot</li>
            </ul>
            <p>Na een klik op het veld selecteer je in het formulier:</p>
            <ul>
              <li>De speler die de poging heeft gedaan</li>
              <li>Het type doelpoging (alleen bij pogingen binnen 6 meter)</li>
              <li>Het resultaat van de doelpoging: raak, op de korf of mis</li>
            </ul>
            <img
              src="/images/vastleggen_doelpoging.png"
              alt="Formulier voor vastleggen doelpoging"
              class="guide__image"
            />
            <p>
              Na het opslaan verschijnt een icoon op de positie van de
              doelpoging:
            </p>
            <ul class="guide__icon-list">
              <li>
                <img
                  src="/images/groen_rondje_wit_vinkje.png"
                  alt="Groen rondje met wit vinkje"
                  class="guide__icon"
                />
                <span
                  ><strong>Groen rondje met wit vinkje</strong> - doelpunt</span
                >
              </li>
              <li>
                <img
                  src="/images/oranje_rondje_witte_cirkel.png"
                  alt="Oranje rondje met witte cirkel"
                  class="guide__icon"
                />
                <span
                  ><strong>Oranje rondje met witte cirkel</strong> - korf geraakt</span
                >
              </li>
              <li>
                <img
                  src="/images/rode_cirkel_wit_kruis.png"
                  alt="Rood rondje met wit kruis"
                  class="guide__icon"
                />
                <span><strong>Rood rondje met wit kruis</strong> - mis</span>
              </li>
            </ul>
            <img
              src="/images/veld_uitleg.png"
              alt="Veld met uitleg van doelpogingen"
              class="guide__image"
            />

            <h3>Wedstrijd beindigen</h3>
            <p>
              Via de scorebordknop ga je door de fases van de wedstrijd: <strong
                >Rust</strong
              >,
              <strong>Hervat</strong> en <strong>Einde</strong>.
            </p>
            <img
              src="/images/scorebord_rust.png"
              alt="Scorebord met rustknop"
              class="guide__image"
            />
            <img
              src="/images/scorebord_hervat.png"
              alt="Scorebord met hervatknop"
              class="guide__image"
            />
            <img
              src="/images/scorebord_einde.png"
              alt="Scorebord met eindeknop"
              class="guide__image"
            />
          </section>

          <section id="wedstrijd-delen" class="guide__section">
            <h2>Wedstrijd delen</h2>
            <p>
              Via de optie <strong>Delen</strong> is het mogelijk om informatie over
              de wedstrijd live te delen. De twee opties zijn:
            </p>
            <ul>
              <li>
                <strong>Liveverslag</strong> - een tijdlijn met live updates over
                de wedstrijd
              </li>
              <li>
                <strong>Live dashboard</strong> - een live overzicht met statistieken
                voor coaches
              </li>
            </ul>
            <p>
              De links bij het liveverslag en het live dashboard kunnen
              gekopieerd en gedeeld worden, bijvoorbeeld via Signal of WhatsApp.
            </p>

            <h3>Liveverslag</h3>
            <p>
              Wanneer de link van het liveverslag wordt geopend verschijnt een
              tijdlijn met acties van de wedstrijd, zoals doelpunten,
              doelpogingen, wissels en functiewissels.
            </p>
            <p>
              Nadat een actie wordt vastgelegd, volgt direct een update in de
              tijdlijn.
            </p>
            <img
              src="/images/liveverslag.png"
              alt="Voorbeeld van liveverslag"
              class="guide__image"
            />

            <h3>Live dashboard</h3>
            <p>
              Het live dashboard is gemaakt voor coaches om tijdens een
              wedstrijd direct inzicht te krijgen in wat er cijfermatig gebeurt.
            </p>
            <ul>
              <li>Linkerkant: statistieken van de eerste aanval</li>
              <li>Rechterkant: statistieken van de eerste verdediging</li>
            </ul>
            <p>
              In de tabel bovenaan staan doelpogingen, doelpunten en percentages
              per vak. Daaronder staan de schotmap en de tegendoelpunten met de
              spelers die ze hebben doorgelaten.
            </p>
            <img
              src="/images/live_dashbord.png"
              alt="Live dashboard voor coaches"
              class="guide__image"
            />
          </section>

          <section id="statistieken" class="guide__section">
            <h2>Statistieken uitgelegd</h2>
            <p>
              Op de pagina met statistieken zijn meerdere filters beschikbaar om
              in te zoomen op spelers, wedstrijden of alle wedstrijden.
            </p>
            <p>
              Via de dropdowns bij <strong>Alle spelers</strong> en <strong
                >Alle wedstrijden</strong
              > kun je bekijken:
            </p>
            <ul>
              <li>Alle spelers over alle wedstrijden</li>
              <li>Een enkele speler over alle wedstrijden</li>
              <li>Alle spelers over een enkele wedstrijd</li>
              <li>Een enkele speler over een wedstrijd</li>
            </ul>
            <img
              src="/images/statistieken_filters.png"
              alt="Filteropties voor statistieken"
              class="guide__image"
            />
            <p>
              Bovenaan staat de tabel <strong
                >Schotverdeling en rendement</strong
              >, met:
            </p>
            <ul>
              <li>Type doelpoging</li>
              <li>Aantal pogingen</li>
              <li>Aantal gescoord</li>
              <li>Percentage</li>
            </ul>
            <p>
              Onder <strong>Aanvalsprestaties</strong> zie je het totaal aantal aanvallen,
              gemiddeld aantal doelpogingen per aanval en het percentage succesvolle
              aanvallen.
            </p>
            <img
              src="/images/statistieken_aanvalsprestaties.png"
              alt="Tabel met aanvalsprestaties"
              class="guide__image"
            />
            <p>
              Daarna volgen de schotmap met alle doelpogingen en de tabel met <strong
                >tegendoelpunten</strong
              > per speler.
            </p>
            <img
              src="/images/statistieken_schotmap.png"
              alt="Schotmap met doelpogingen"
              class="guide__image"
            />
            <img
              src="/images/statistieken_tegendoelpunten.png"
              alt="Tabel met tegendoelpunten"
              class="guide__image"
            />
          </section>
        </article>
      </div>
    </Section>
  </main>
</BaseLayout>

<script>
  const sections = document.querySelectorAll<HTMLElement>(".guide__section");
  const navLinks = document.querySelectorAll<HTMLAnchorElement>(".guide__nav-link");
  const navSummaryCurrent = document.querySelector<HTMLElement>(".guide__nav-summary-current");
  const navDropdown = document.querySelector<HTMLDetailsElement>(".guide__nav-dropdown");
  const navDropdownLinks = document.querySelectorAll<HTMLAnchorElement>(
    ".guide__nav-link--dropdown",
  );
  const OFFSET = 168;

  function updateActiveLink() {
    if (sections.length === 0) {
      return;
    }

    let activeId: string | null = null;

    for (const section of sections) {
      if (section.getBoundingClientRect().top <= OFFSET) {
        activeId = section.id;
      }
    }

    const atBottom =
      window.innerHeight + Math.ceil(window.scrollY) >=
      document.documentElement.scrollHeight;

    if (atBottom) {
      activeId = sections[sections.length - 1].id;
    }

    if (!activeId) {
      activeId = sections[0].id;
    }

    for (const link of navLinks) {
      link.classList.toggle(
        "is-active",
        link.getAttribute("href") === `#${activeId}`,
      );
    }

    if (navSummaryCurrent && activeId) {
      const activeDesktopLink = document.querySelector<HTMLAnchorElement>(
        `.guide__nav-list .guide__nav-link[href="#${activeId}"]`,
      );
      navSummaryCurrent.textContent = activeDesktopLink?.textContent?.trim() ?? "";
    }
  }

  for (const link of navDropdownLinks) {
    link.addEventListener("click", () => {
      navDropdown?.removeAttribute("open");
    });
  }

  window.addEventListener("hashchange", () => {
    updateActiveLink();
  });

  window.addEventListener("scroll", updateActiveLink, { passive: true });
  updateActiveLink();
</script>

<style>
  .guide {
    display: var(--flex-medium, grid);
    grid-template-columns: 4fr 8fr;
    gap: var(--space-8);
    flex-flow: column;
  }

  .guide__nav-inner {
    position: sticky;
    top: 10rem;
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.12);
    border-radius: 0.9rem;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
    padding: 0.85rem;
  }

  .guide__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .guide__nav-list li + li {
    margin-top: 0.15rem;
  }

  .guide__nav-dropdown {
    display: none;
    margin: 0;
    border: 1px solid rgba(15, 23, 42, 0.14);
    border-radius: 0.8rem;
    background: #fff;
    overflow: clip;
  }

  .guide__nav-summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    padding: 0.65rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    position: relative;
    transition: background-color 160ms ease;
  }

  .guide__nav-summary::-webkit-details-marker {
    display: none;
  }

  .guide__nav-summary::after {
    content: "";
    position: absolute;
    right: 0.9rem;
    top: 50%;
    width: 0.45rem;
    height: 0.45rem;
    border-right: 2px solid color-mix(in srgb, var(--theme-color-text) 75%, #0f172a);
    border-bottom: 2px solid color-mix(in srgb, var(--theme-color-text) 75%, #0f172a);
    transform: translateY(-65%) rotate(45deg);
    transition: transform 160ms ease;
  }

  .guide__nav-dropdown[open] .guide__nav-summary::after {
    transform: translateY(-35%) rotate(-135deg);
  }

  .guide__nav-summary:hover {
    background: color-mix(in srgb, #ffffff 70%, var(--theme-color-text) 8%);
  }

  .guide__nav-summary-label {
    font-size: 0.78rem;
    color: color-mix(in srgb, var(--theme-color-text) 62%, #475569);
  }

  .guide__nav-summary-current {
    font-weight: 600;
    color: color-mix(in srgb, var(--theme-color-text) 94%, #0f172a);
    padding-inline-end: 1.15rem;
  }

  .guide__nav-dropdown-list {
    list-style: none;
    margin: 0;
    padding: 0.45rem;
    border-top: 1px solid rgba(15, 23, 42, 0.1);
    display: grid;
    gap: 0.15rem;
  }

  .guide__nav-link {
    display: block;
    text-decoration: none;
    color: color-mix(in srgb, var(--theme-color-text) 90%, #0f172a);
    border-radius: 0.5rem;
    padding: 0.4rem 0.55rem;
    transition:
      background-color 160ms ease,
      color 160ms ease;
  }

  .guide__nav-link:hover {
    background: color-mix(in srgb, #ffffff 70%, var(--theme-color-text) 8%);
  }

  .guide__nav-link.is-active {
    background: color-mix(in srgb, var(--theme-color-text) 9%, #ffffff);
    color: color-mix(in srgb, var(--theme-color-text) 95%, #0f172a);
    font-weight: 600;
  }

  .guide__section {
    padding-block-start: 10rem;
  }

  @media (max-width: 56rem) {
    .guide__nav-inner {
      position: static;
      margin-block-end: var(--space-4);
    }

    .guide__nav-list {
      display: none;
    }

    .guide__nav-dropdown {
      display: block;
    }
  }
</style>
